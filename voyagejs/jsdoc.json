{
  "source": {
      "include": ["voyage.js"],
      "includePattern": ".js$",
      "excludePattern": "(node_modules/|docs)"
  },
  "plugins": ["plugins/markdown"],
  "opts": {
      "encoding": "utf8",
      "destination": "docs/",
      "recurse": true,
      "verbose": true,
      "template": "",
      "theme_opts": {
          "default_theme": "dark"
      }
  },
  "markdown": {
      "hardwrap": false,
      "idInHeadings": true
  }
}